<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground — 108dp canvas.
    Safe zone: 72dp centered (18dp margin each side).
    The shield is drawn at 70x70dp centered at (54,54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield body (red) -->
    <path
        android:fillColor="#FF1744"
        android:pathData="M54,22 L76,32 L76,56 C76,70 65,80 54,84 C43,80 32,70 32,56 L32,32 Z" />

    <!-- Shield depth face -->
    <path
        android:fillColor="#CC001A"
        android:pathData="M54,27 L73,36 L73,56 C73,68 63,77 54,81 C45,77 35,68 35,56 L35,36 Z" />

    <!-- Play button triangle (white) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.9"
        android:pathData="M47,42 L65,54 L47,66 Z" />

    <!-- Slash shadow -->
    <path
        android:strokeColor="#660000"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:pathData="M36,36 L72,72"
        android:fillColor="#00000000" />

    <!-- Slash white -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:pathData="M36,36 L72,72"
        android:fillColor="#00000000" />

</vector>
