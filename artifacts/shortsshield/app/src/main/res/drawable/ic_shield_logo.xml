<?xml version="1.0" encoding="utf-8"?>
<!--
    ShortsShield brand logo: bold shield with a red gradient body,
    a white play-button triangle inside, and a thick diagonal slash
    crossing out the play button — symbolising "blocked".
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Shield outer (deep red) -->
    <path
        android:fillColor="#FF1744"
        android:pathData="M24,4 L40,11 L40,27 C40,36 32,43 24,46 C16,43 8,36 8,27 L8,11 Z" />

    <!-- Shield inner face (slightly lighter for depth) -->
    <path
        android:fillColor="#E5002B"
        android:pathData="M24,8 L37,14 L37,27 C37,34.5 30,40.5 24,43 C18,40.5 11,34.5 11,27 L11,14 Z" />

    <!-- Play triangle (white, crisp) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.95"
        android:pathData="M20,17 L32,24 L20,31 Z" />

    <!-- Block slash — dark shadow stroke (wide) -->
    <path
        android:strokeColor="#800000"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:pathData="M13,13 L35,35"
        android:fillColor="#00000000" />

    <!-- Block slash — bright white core -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M13,13 L35,35"
        android:fillColor="#00000000" />

</vector>
