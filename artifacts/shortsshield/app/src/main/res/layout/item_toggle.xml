<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable toggle row. Titles/subtitles are set programmatically from MainActivity.
    The switch IDs are stable: switchBlockPlayer, switchHideShelf, etc.
    Each row is included with a unique android:id so ViewBinding finds it.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="60dp"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingEnd="12dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/toggleTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feature"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/toggleSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/on_surface_dim"
            android:textSize="12sp"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/toggleSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true" />
</LinearLayout>
